---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Shermaine — The Life" description="Running, climbing, dancing, and creating.">

  <!-- ── NAV ─────────────────────────────────── -->
  <header class="border-b border-line bg-white sticky top-0 z-50">
    <div class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="font-serif text-lg text-ink">Shermi</a>
      <nav class="flex items-center gap-6">
        <a href="#running"  class="life-nav">Running</a>
        <a href="#climbing" class="life-nav">Climbing</a>
        <a href="#dance"    class="life-nav">Dance</a>
        <a href="#creating" class="life-nav">Creating</a>
      </nav>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-6">

    <!-- ── HERO ──────────────────────────────── -->
    <section class="pt-16 pb-12 border-b border-line">
      <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-8 items-end">
        <div>
          <p class="text-xs tracking-[0.18em] uppercase font-medium text-ink-light mb-4">life.shermi.dev</p>
          <h1 class="font-serif text-[clamp(3rem,8vw,5.5rem)] leading-none mb-4">
            The<br/><em class="italic text-pink-deep">Life</em>
          </h1>
          <p class="text-ink-mid leading-relaxed max-w-sm text-[0.95rem]">
            Marathon runner. Rock climber. Lifelong dancer. Content creator.
            This is everything outside the lab.
          </p>
        </div>

        <!-- Hero photo -->
        <!-- ✏️ Replace with: <img src="/photos/hero.jpg" alt="Shermaine" class="w-48 h-48 sm:w-56 sm:h-64 object-cover rounded-2xl" /> -->
        <div class="photo-slot w-48 h-48 sm:w-56 sm:h-64 rounded-2xl shrink-0 mx-auto sm:mx-0">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          <span>Your photo</span>
        </div>
      </div>
    </section>

    <!-- ── RUNNING ────────────────────────────── -->
    <section id="running" class="py-14 border-b border-line">

      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-serif text-3xl">Running</h2>
        <span class="text-xs tracking-widest uppercase text-pink-deep font-medium">01</span>
      </div>

      <!-- Stats row -->
      <div class="grid grid-cols-3 divide-x divide-line border border-line rounded-xl mb-8 bg-pink-soft fade-in">
        <!-- ✏️ Update with your real stats -->
        <div class="text-center py-6">
          <div class="font-serif text-3xl text-ink">42.2</div>
          <div class="text-[0.65rem] tracking-widest uppercase text-pink-deep font-medium mt-1">km</div>
          <div class="text-xs text-ink-light mt-0.5">Finished</div>
        </div>
        <div class="text-center py-6">
          <div class="font-serif text-3xl text-ink">X:XX</div>
          <div class="text-[0.65rem] tracking-widest uppercase text-pink-deep font-medium mt-1">finish time</div>
          <!-- ✏️ Update race name -->
          <div class="text-xs text-ink-light mt-0.5">Your Race Name</div>
        </div>
        <div class="text-center py-6">
          <div class="font-serif text-3xl text-ink">20XX</div>
          <div class="text-[0.65rem] tracking-widest uppercase text-pink-deep font-medium mt-1">year</div>
          <div class="text-xs text-ink-light mt-0.5">Race day</div>
        </div>
      </div>

      <!-- Photos grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6 fade-in">
        <!-- ✏️ Replace each photo-slot with an <img> tag -->
        <!-- e.g. <img src="/photos/running-1.jpg" alt="Race day" class="w-full aspect-[4/5] object-cover rounded-xl" /> -->
        <div class="photo-slot aspect-[4/5] rounded-xl">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
          <span>Race day photo</span>
        </div>
        <div class="photo-slot aspect-[4/5] rounded-xl">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
          <span>Training run</span>
        </div>
        <div class="photo-slot aspect-[4/5] rounded-xl col-span-2 sm:col-span-1">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
          <span>Finish line</span>
        </div>
      </div>

      <p class="text-ink-mid text-[0.92rem] leading-relaxed fade-in">
        Running 42.2 kilometres is not a rational decision. It is a commitment you make to yourself
        and then spend months honouring — through early mornings, tired legs, and the quiet satisfaction
        of the long run. I crossed that finish line and I'd do it again.
      </p>
    </section>

    <!-- ── CLIMBING ───────────────────────────── -->
    <section id="climbing" class="py-14 border-b border-line">

      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-serif text-3xl">Climbing</h2>
        <span class="text-xs tracking-widest uppercase text-pink-deep font-medium">02</span>
      </div>

      <!-- Wide photo + text -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6 fade-in">
        <!-- ✏️ Replace with: <img src="/photos/climbing-1.jpg" alt="Climbing" class="w-full aspect-square object-cover rounded-xl" /> -->
        <div class="photo-slot aspect-square rounded-xl">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
          <span>On the wall</span>
        </div>
        <div class="photo-slot aspect-square rounded-xl">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
          <span>Bouldering / route</span>
        </div>
      </div>

      <div class="flex flex-wrap gap-x-10 gap-y-2 mb-4 fade-in">
        <!-- ✏️ Update style and grade -->
        <div><span class="text-[0.65rem] uppercase tracking-widest font-medium text-ink-light">Style</span><p class="text-sm text-ink mt-0.5">Sport / Bouldering / Trad</p></div>
        <div><span class="text-[0.65rem] uppercase tracking-widest font-medium text-ink-light">Grade</span><p class="text-sm text-ink mt-0.5">5.XX / VX</p></div>
      </div>

      <p class="text-ink-mid text-[0.92rem] leading-relaxed fade-in">
        Climbing is problem-solving with your whole body. Every route is a puzzle — read the wall,
        commit to the move, trust your feet. No data to clean, no reviewers to convince.
        Just you and the wall.
      </p>
    </section>

    <!-- ── DANCE ──────────────────────────────── -->
    <section id="dance" class="py-14 border-b border-line">

      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-serif text-3xl">Dance</h2>
        <span class="text-xs tracking-widest uppercase text-pink-deep font-medium">03</span>
      </div>

      <!-- Photos -->
      <div class="grid grid-cols-2 gap-3 mb-6 fade-in">
        <!-- ✏️ Replace with dance photos -->
        <div class="photo-slot aspect-[3/4] rounded-xl">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
          <span>Dance photo 1</span>
        </div>
        <div class="grid grid-rows-2 gap-3">
          <div class="photo-slot rounded-xl">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
            <span>In studio</span>
          </div>
          <div class="photo-slot rounded-xl">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
            <span>Dance photo 3</span>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-x-10 gap-y-2 mb-4 fade-in">
        <!-- ✏️ Update dance styles -->
        <div><span class="text-[0.65rem] uppercase tracking-widest font-medium text-ink-light">Styles</span><p class="text-sm text-ink mt-0.5">Your Dance Styles Here</p></div>
        <div><span class="text-[0.65rem] uppercase tracking-widest font-medium text-ink-light">Since</span><p class="text-sm text-ink mt-0.5">Age 3</p></div>
        <div><span class="text-[0.65rem] uppercase tracking-widest font-medium text-ink-light">Status</span><p class="text-sm text-pink-deep mt-0.5 font-medium">Back at it ✦</p></div>
      </div>

      <p class="text-ink-mid text-[0.92rem] leading-relaxed fade-in">
        Since I was 3, dance has been my first language. Life got busy — research has a way of consuming
        you — but I'm back in the studio, back in my body, documenting the journey. Some things you
        don't grow out of. You just grow back into them.
      </p>
    </section>

    <!-- ── CREATING ───────────────────────────── -->
    <section id="creating" class="py-14">

      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-serif text-3xl">Creating</h2>
        <span class="text-xs tracking-widest uppercase text-pink-deep font-medium">04</span>
      </div>

      <p class="text-ink-mid text-[0.92rem] leading-relaxed mb-8 fade-in max-w-lg">
        I document it all — the long runs, the bouldering sessions, the dance comeback, the research life.
        On TikTok and Instagram, where the scientist, the athlete, and the performer all get to show up
        in one place.
      </p>

      <!-- Social cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10 fade-in">

        <!-- ✏️ Update TikTok handle -->
        <a href="https://www.tiktok.com/@YOUR_TIKTOK_HANDLE" class="creator-card bg-[#0D0D0D] border-[#2a2a2a]" target="_blank" rel="noopener">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="white" class="shrink-0">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.31 6.31 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.16 8.16 0 004.77 1.52V6.73a4.85 4.85 0 01-1-.04z"/>
          </svg>
          <div class="flex-1">
            <p class="text-[0.65rem] tracking-widest uppercase font-medium text-white/40 mb-0.5">TikTok</p>
            <!-- ✏️ Update handle -->
            <p class="text-sm font-semibold text-white">@YOUR_TIKTOK_HANDLE</p>
          </div>
          <span class="text-white/30 text-lg">↗</span>
        </a>

        <!-- ✏️ Update Instagram handle -->
        <a href="https://www.instagram.com/YOUR_INSTAGRAM_HANDLE" class="creator-card bg-off-white border-line" target="_blank" rel="noopener">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="#C13584" class="shrink-0">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
          <div class="flex-1">
            <p class="text-[0.65rem] tracking-widest uppercase font-medium text-ink-light mb-0.5">Instagram</p>
            <!-- ✏️ Update handle -->
            <p class="text-sm font-semibold text-ink">@YOUR_INSTAGRAM_HANDLE</p>
          </div>
          <span class="text-ink/30 text-lg">↗</span>
        </a>

      </div>

      <!-- Content type tags -->
      <div class="flex flex-wrap gap-2 fade-in">
        <span class="content-tag">🔬 Research life</span>
        <span class="content-tag">💃 Dance videos</span>
        <span class="content-tag">🧗 Climbing clips</span>
        <span class="content-tag">🏃 Running content</span>
        <span class="content-tag">📍 Behind the scenes</span>
      </div>

    </section>

  </main>

  <!-- ── FOOTER ─────────────────────────────── -->
  <footer class="border-t border-line py-5 px-6 bg-pink-soft">
    <div class="max-w-3xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2">
      <span class="text-xs text-ink-light">© 2025 Shermaine</span>
      <div class="flex gap-5">
        <a href="/" class="text-xs text-ink-light hover:text-pink-deep transition-colors">← Home</a>
        <a href="/nerdy" class="text-xs text-ink-light hover:text-pink-deep transition-colors">The Research →</a>
      </div>
    </div>
  </footer>

</Layout>

<style>
  .life-nav {
    @apply text-xs tracking-widest uppercase font-medium text-ink-light
           hover:text-pink-deep transition-colors;
  }
  .creator-card {
    @apply flex items-center gap-4 px-5 py-4 rounded-xl border-[1.5px] no-underline
           hover:border-pink transition-colors duration-200;
  }
  .content-tag {
    @apply text-xs font-medium px-3 py-1.5
           bg-pink-soft border border-pink rounded-full text-ink-mid;
  }
</style>

<script>
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const t = document.querySelector((a as HTMLAnchorElement).getAttribute('href')!);
      if (!t) return; e.preventDefault();
      window.scrollTo({ top: (t as HTMLElement).offsetTop - 56, behavior: 'smooth' });
    });
  });
</script>
