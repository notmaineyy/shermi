---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Shermaine — Research" description="Academic portfolio — research, publications, and code.">

  <!-- ── NAV ─────────────────────────────────── -->
  <header class="border-b border-line bg-white sticky top-0 z-50">
    <div class="max-w-4xl mx-auto px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="font-serif text-lg text-ink">Shermaine</span>
        <span class="text-line text-lg select-none">·</span>
        <!-- ✏️ Update your title / position -->
        <span class="text-xs text-ink-light tracking-wide hidden sm:block">Researcher</span>
      </div>
      <nav class="flex items-center gap-6">
        <a href="#research"     class="acad-nav">Research</a>
        <a href="#publications" class="acad-nav">Publications</a>
        <a href="#code"         class="acad-nav">Code</a>
        <a href="#contact"      class="acad-nav">Contact</a>
      </nav>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-6">

    <!-- ── PROFILE ──────────────────────────────── -->
    <section class="py-16 grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-10 items-start border-b border-line">

      <!-- Headshot -->
      <div class="fade-in">
        <!-- ✏️ Replace this div with: <img src="/photos/headshot.jpg" alt="Shermaine" class="w-full aspect-square object-cover rounded-lg" /> -->
        <div class="photo-slot w-full aspect-square rounded-lg">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          <span>Headshot</span>
        </div>
      </div>

      <!-- Bio -->
      <div class="fade-in">
        <h1 class="font-serif text-[2.6rem] leading-tight mb-1">Shermaine</h1>
        <!-- ✏️ Update your title, department, university -->
        <p class="text-ink-mid text-sm mb-1">PhD Candidate / Researcher · Department of [Field]</p>
        <p class="text-ink-light text-sm mb-6">[University Name] · [City, Country]</p>

        <p class="text-ink-mid leading-relaxed text-[0.95rem] mb-4">
          <!-- ✏️ Write your academic bio here -->
          I am a researcher in [field], broadly interested in [research area 1], [research area 2],
          and [research area 3]. My work sits at the intersection of [discipline A] and [discipline B],
          with a focus on [specific problem or question].
        </p>
        <p class="text-ink-mid leading-relaxed text-[0.95rem] mb-6">
          Prior to [current position], I [brief background — previous degrees, institutions, or experience].
          Outside the lab, I run marathons, climb, and dance. I also make content about all of the above.
        </p>

        <!-- Quick links -->
        <div class="flex flex-wrap gap-2">
          <!-- ✏️ Update all links -->
          <a href="mailto:your@email.com"                        class="acad-chip">Email</a>
          <a href="https://scholar.google.com/citations?user=X"  class="acad-chip" target="_blank" rel="noopener">Google Scholar</a>
          <a href="https://github.com/YOUR_GITHUB"               class="acad-chip" target="_blank" rel="noopener">GitHub</a>
          <a href="https://linkedin.com/in/YOUR_LINKEDIN"        class="acad-chip" target="_blank" rel="noopener">LinkedIn</a>
          <a href="/cv.pdf"                                       class="acad-chip acad-chip-pink" target="_blank" rel="noopener">CV / Résumé ↓</a>
        </div>
      </div>
    </section>

    <!-- ── RESEARCH INTERESTS ─────────────────── -->
    <section class="py-12 border-b border-line fade-in">
      <h2 class="acad-section-title">Research Interests</h2>
      <!-- ✏️ Update your research interest tags -->
      <div class="flex flex-wrap gap-2 mt-4">
        <span class="interest-tag">Research Area 1</span>
        <span class="interest-tag">Research Area 2</span>
        <span class="interest-tag">Research Area 3</span>
        <span class="interest-tag">Methodology / Technique</span>
        <span class="interest-tag">Application Domain</span>
      </div>
    </section>

    <!-- ── RESEARCH PROJECTS ──────────────────── -->
    <section id="research" class="py-12 border-b border-line">
      <h2 class="acad-section-title fade-in">Research</h2>

      <div class="space-y-8 mt-6">

        <!-- ✏️ Replace with your real projects -->
        <div class="research-row fade-in">
          <div class="research-year">20XX</div>
          <div>
            <h3 class="font-serif text-xl mb-1 leading-snug">Your Research Project Title</h3>
            <p class="text-ink-light text-xs tracking-widest uppercase mb-2 font-medium">Research Area · [Collaborators / Funder]</p>
            <p class="text-ink-mid text-[0.92rem] leading-relaxed mb-3">
              A clear description of the research question, methodology, and contribution. What problem does this work address? What approach did you take? What did you find or build?
            </p>
            <div class="flex flex-wrap gap-1.5">
              <span class="method-tag">Method / Tool</span>
              <span class="method-tag">Dataset</span>
              <span class="method-tag">Outcome</span>
            </div>
          </div>
        </div>

        <div class="research-row fade-in">
          <div class="research-year">20XX</div>
          <div>
            <h3 class="font-serif text-xl mb-1 leading-snug">Second Research Project Title</h3>
            <p class="text-ink-light text-xs tracking-widest uppercase mb-2 font-medium">Research Area · [Collaborators]</p>
            <p class="text-ink-mid text-[0.92rem] leading-relaxed mb-3">
              Description of the project. Focus on what makes it distinct and why it matters. You can mention ongoing status if it's not finished.
            </p>
            <div class="flex flex-wrap gap-1.5">
              <span class="method-tag">Method</span>
              <span class="method-tag">In Progress</span>
            </div>
          </div>
        </div>

        <div class="research-row fade-in">
          <div class="research-year">20XX</div>
          <div>
            <h3 class="font-serif text-xl mb-1 leading-snug">Third Project or Thesis Work</h3>
            <p class="text-ink-light text-xs tracking-widest uppercase mb-2 font-medium">Research Area · Thesis / Dissertation</p>
            <p class="text-ink-mid text-[0.92rem] leading-relaxed mb-3">
              Brief overview. Link to thesis document or repository if available.
            </p>
            <div class="flex flex-wrap gap-1.5">
              <span class="method-tag">Thesis</span>
              <span class="method-tag">Method</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── PUBLICATIONS ───────────────────────── -->
    <section id="publications" class="py-12 border-b border-line">
      <h2 class="acad-section-title fade-in">Publications</h2>

      <div class="space-y-0 mt-6">

        <!-- ✏️ Replace with your real publications -->
        <div class="pub-row fade-in">
          <div class="pub-year">20XX</div>
          <div class="flex-1 min-w-0">
            <p class="font-medium text-ink leading-snug mb-0.5">
              Paper Title Here: And Its Subtitle if It Has One
            </p>
            <p class="text-sm text-ink-mid mb-0.5">
              <strong>Shermaine [Last Name]</strong>, Co-Author Name, Another Author
            </p>
            <p class="text-xs text-ink-light italic mb-2">
              <em>Journal or Conference Name</em>, Volume(Issue), pp. XX–XX
            </p>
            <div class="flex gap-3">
              <a href="#" class="pub-link">PDF</a>
              <a href="#" class="pub-link">DOI</a>
              <a href="#" class="pub-link">Code</a>
            </div>
          </div>
        </div>

        <div class="pub-row fade-in">
          <div class="pub-year">20XX</div>
          <div class="flex-1 min-w-0">
            <p class="font-medium text-ink leading-snug mb-0.5">
              Second Publication Title Goes Here
            </p>
            <p class="text-sm text-ink-mid mb-0.5">
              <strong>Shermaine [Last Name]</strong>, Co-Author Name
            </p>
            <p class="text-xs text-ink-light italic mb-2">
              <em>Conference Name (CONF'XX)</em>, City, Country
            </p>
            <div class="flex gap-3">
              <a href="#" class="pub-link">PDF</a>
              <a href="#" class="pub-link">DOI</a>
            </div>
          </div>
        </div>

        <div class="pub-row fade-in">
          <div class="pub-year">20XX</div>
          <div class="flex-1 min-w-0">
            <p class="font-medium text-ink leading-snug mb-0.5">
              Preprint or Working Paper Title
            </p>
            <p class="text-sm text-ink-mid mb-0.5">
              <strong>Shermaine [Last Name]</strong> et al.
            </p>
            <p class="text-xs text-ink-light italic mb-2">
              <em>arXiv / bioRxiv / SSRN</em> · Preprint
            </p>
            <div class="flex gap-3">
              <a href="#" class="pub-link">Preprint</a>
              <a href="#" class="pub-link">Code</a>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── ACADEMIC FEATURES ──────────────────── -->
    <section class="py-12 border-b border-line">
      <h2 class="acad-section-title fade-in">Talks &amp; Recognition</h2>
      <div class="space-y-4 mt-6">

        <!-- ✏️ Replace with real talks, awards, press -->
        <div class="talk-row fade-in">
          <div class="talk-year">20XX</div>
          <div>
            <p class="text-ink font-medium leading-snug">Talk or Award Title</p>
            <p class="text-sm text-ink-light">Conference / Institution Name · City</p>
          </div>
          <a href="#" class="pub-link shrink-0 self-start mt-0.5">Slides →</a>
        </div>

        <div class="talk-row fade-in">
          <div class="talk-year">20XX</div>
          <div>
            <p class="text-ink font-medium leading-snug">Award or Fellowship Name</p>
            <p class="text-sm text-ink-light">Awarding Body · Description</p>
          </div>
        </div>

        <div class="talk-row fade-in">
          <div class="talk-year">20XX</div>
          <div>
            <p class="text-ink font-medium leading-snug">Invited Talk or Panel Title</p>
            <p class="text-sm text-ink-light">Event / Podcast / Newsletter · Platform</p>
          </div>
          <a href="#" class="pub-link shrink-0 self-start mt-0.5">Watch →</a>
        </div>

      </div>
    </section>

    <!-- ── CODE ──────────────────────────────────── -->
    <section id="code" class="py-12 border-b border-line">
      <h2 class="acad-section-title fade-in">Software &amp; Code</h2>
      <div class="space-y-4 mt-6">

        <!-- ✏️ Replace with your real repos -->
        <div class="code-row fade-in">
          <div class="font-mono text-xs text-pink-deep font-medium w-20 shrink-0 pt-0.5">Python</div>
          <div class="flex-1 min-w-0">
            <a href="#" class="font-medium text-ink hover:text-pink-deep transition-colors" target="_blank" rel="noopener">project-name</a>
            <p class="text-sm text-ink-light mt-0.5">A short description of what this does and why you built it.</p>
          </div>
          <a href="https://github.com/YOUR_USERNAME/project-name" class="pub-link shrink-0" target="_blank" rel="noopener">GitHub →</a>
        </div>

        <div class="code-row fade-in">
          <div class="font-mono text-xs text-pink-deep font-medium w-20 shrink-0 pt-0.5">R</div>
          <div class="flex-1 min-w-0">
            <a href="#" class="font-medium text-ink hover:text-pink-deep transition-colors" target="_blank" rel="noopener">analysis-repo</a>
            <p class="text-sm text-ink-light mt-0.5">Analysis or visualisation code from your research — reproducibility matters.</p>
          </div>
          <a href="https://github.com/YOUR_USERNAME/analysis-repo" class="pub-link shrink-0" target="_blank" rel="noopener">GitHub →</a>
        </div>

        <div class="code-row fade-in">
          <div class="font-mono text-xs text-pink-deep font-medium w-20 shrink-0 pt-0.5">Astro</div>
          <div class="flex-1 min-w-0">
            <a href="#" class="font-medium text-ink hover:text-pink-deep transition-colors" target="_blank" rel="noopener">this-website</a>
            <p class="text-sm text-ink-light mt-0.5">Personal portfolio — Astro + Tailwind, because why not.</p>
          </div>
          <a href="https://github.com/YOUR_USERNAME/shermi-portfolio" class="pub-link shrink-0" target="_blank" rel="noopener">GitHub →</a>
        </div>

      </div>
    </section>

    <!-- ── CONTACT ────────────────────────────── -->
    <section id="contact" class="py-12">
      <h2 class="acad-section-title fade-in">Contact</h2>
      <div class="mt-4 fade-in space-y-1 text-[0.92rem] text-ink-mid">
        <!-- ✏️ Update all contact details -->
        <p>📧 <a href="mailto:your@email.com" class="hover:text-pink-deep transition-colors">your@email.com</a></p>
        <p>🏫 [Office / Room Number], [Building], [University]</p>
        <p>🔗 <a href="https://scholar.google.com/citations?user=X" class="hover:text-pink-deep transition-colors" target="_blank" rel="noopener">Google Scholar</a>
           &nbsp;·&nbsp;
           <a href="https://github.com/YOUR_GITHUB" class="hover:text-pink-deep transition-colors" target="_blank" rel="noopener">GitHub</a>
           &nbsp;·&nbsp;
           <a href="https://linkedin.com/in/YOUR_LINKEDIN" class="hover:text-pink-deep transition-colors" target="_blank" rel="noopener">LinkedIn</a>
        </p>
      </div>
    </section>

  </main>

  <!-- ── FOOTER ─────────────────────────────── -->
  <footer class="border-t border-line py-5 px-6">
    <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2">
      <span class="text-xs text-ink-light">© 2025 Shermaine</span>
      <div class="flex gap-5">
        <!-- ✏️ Update links -->
        <a href="/" class="text-xs text-ink-light hover:text-pink-deep transition-colors">← Back to home</a>
        <a href="/life" class="text-xs text-ink-light hover:text-pink-deep transition-colors">The Life →</a>
      </div>
    </div>
  </footer>

</Layout>

<style>
  .acad-nav {
    @apply text-xs tracking-widest uppercase font-medium text-ink-light
           hover:text-pink-deep transition-colors;
  }
  .acad-section-title {
    @apply font-serif text-2xl text-ink;
  }
  .acad-chip {
    @apply text-xs tracking-wide font-medium px-3 py-1
           border border-line rounded-full text-ink-mid
           hover:border-pink hover:bg-pink-soft transition-colors no-underline;
  }
  .acad-chip-pink {
    @apply bg-pink-soft border-pink text-ink hover:bg-pink hover:border-pink;
  }
  .interest-tag {
    @apply text-xs font-medium px-3 py-1 bg-pink-soft border border-pink rounded-full text-ink-mid;
  }
  .method-tag {
    @apply text-[0.65rem] tracking-wide uppercase font-medium px-2.5 py-0.5
           bg-off-white border border-line rounded-full text-ink-light;
  }
  .research-row {
    @apply grid grid-cols-[56px_1fr] gap-6 pb-8 border-b border-line last:border-0 last:pb-0;
  }
  .research-year {
    @apply font-mono text-xs text-ink-light pt-1.5;
  }
  .pub-row {
    @apply flex gap-6 py-5 border-b border-line last:border-0;
  }
  .pub-year {
    @apply font-mono text-xs text-ink-light pt-0.5 w-12 shrink-0;
  }
  .pub-link {
    @apply text-xs font-medium text-pink-deep
           hover:underline transition-colors no-underline;
  }
  .talk-row {
    @apply flex items-start gap-6 py-4 border-b border-line last:border-0;
  }
  .talk-year {
    @apply font-mono text-xs text-ink-light pt-0.5 w-12 shrink-0;
  }
  .code-row {
    @apply flex items-start gap-4 py-4 border-b border-line last:border-0;
  }
</style>

<script>
  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const t = document.querySelector((a as HTMLAnchorElement).getAttribute('href')!);
      if (!t) return; e.preventDefault();
      window.scrollTo({ top: (t as HTMLElement).offsetTop - 56, behavior: 'smooth' });
    });
  });
</script>
