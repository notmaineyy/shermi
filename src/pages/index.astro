---
import Layout from '../layouts/Layout.astro';
---
<Layout title="shermaine">
  <main class="min-h-screen bg-off-white flex flex-col items-center justify-center px-6 relative overflow-hidden py-12">

    <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-pink-soft opacity-70 blur-[100px] pointer-events-none -translate-y-1/3 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 rounded-full bg-pink-muted opacity-60 blur-[80px] pointer-events-none translate-y-1/3 -translate-x-1/3"></div>

    <div class="relative z-10 text-center max-w-lg w-full"> <img 
        src="/photo/main.jpg" 
        class="w-56 h-56 rounded-full object-cover mx-auto mb-6 border-4 border-white shadow-[0_4px_20px_rgba(242,196,206,0.4)]"
      />

      <h1 class="font-serif text-[clamp(3rem,8vw,3.5rem)] leading-none mb-2">
        shermaine
      </h1>
      <p class="text-ink-light text-sm tracking-[0.18em] lowercase font-medium mb-5">
        or you might know me as shermi!
      </p>

      <p class="text-ink text-sm leading-relaxed max-w-sm mx-auto mb-10">
        hellooo! i am shermaine and have recently graduated from imperial with an msc in computing. i like computer vision, travelling, dancing, my <a href="https://nelaggy.com/" class="text-pink-deep">boyfriend</a>, climbing & filming tiktoks! 
      </p>

      

      <div class="flex flex-col items-center mb-4">
        
        <p class="text-ink-light text-sm tracking-widest lowercase mb-5">
          more about me here!!!
        </p>

        <div class="flex flex-col sm:flex-row justify-center items-center gap-4 w-full">
          <a href="/nerdy" class="hub-card group">
            <span class="hub-label-pink">work</span>
          </a>

          <a href="/life" class="hub-card group">
            <span class="hub-label-pink">life</span>
          </a>
        </div>

      </div>

      <div class="mt-12 flex justify-center flex-wrap gap-6 text-ink-light text-[0.68rem] tracking-widest uppercase font-medium">
        <a href="mailto:shermaineang2802@email.com" class="hover:text-pink-deep transition-colors">Email</a>
        <a href="https://github.com/notmaineyy" target="_blank" rel="noopener noreferrer" class="hover:text-pink-deep transition-colors">GitHub</a>
        <a href="https://linkedin.com/in/shermaine-ajn" target="_blank" rel="noopener noreferrer" class="hover:text-pink-deep transition-colors">LinkedIn</a>
      </div>

    </div>
  </main>
</Layout>

<style>
  /* Sleek pill shape with a soft hover glow */
  .hub-card {
    @apply w-32 py-2.5 flex items-center justify-center rounded-full
           border-2 border-pink-soft bg-white
           hover:bg-pink-soft/30 hover:border-pink-deep hover:shadow-[0_4px_20px_rgba(242,196,206,0.4)]
           hover:-translate-y-0.5 transition-all duration-300 no-underline;
  }
  
  /* Centered text, removed margins */
  .hub-label-pink {
    @apply font-serif text-lg text-pink-deep tracking-wide;
  }
</style>