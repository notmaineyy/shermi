---
import Layout from '../layouts/Layout.astro';
---
<Layout title="shermi — life" description="running, climbing, dancing, travel.">

  <header class="border-b border-slate-200 bg-white sticky top-0 z-50">
    <div class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="font-serif text-lg text-slate-900 hover:text-pink-500 transition-colors">shermi</a>
      <nav class="flex items-center gap-6">
        <a href="/" class="text-xs tracking-widest uppercase font-medium text-slate-500
           hover:text-pink-500 transition-colors">home</a>
        <a href="/nerdy" class="text-xs tracking-widest uppercase font-medium text-slate-500
           hover:text-pink-500 transition-colors">work</a>
      </nav>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-6 py-16">

    <div class="mb-14 text-center fade-in">
      <h1 class="font-serif text-[clamp(2.5rem,6vw,4rem)] leading-none mb-3 text-slate-900">
        my life
      </h1>
      <p class="text-slate-500 text-sm tracking-widest lowercase font-medium mb-6">
        everything outside the office.
      </p>
      
      <div class="flex justify-center gap-4">
        <a href="https://www.tiktok.com/@sshermii" target="_blank" rel="noopener"
           class="text-slate-400 hover:text-pink-500 transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
          </svg>
        </a>
        <a href="https://www.instagram.com/sshermii" target="_blank" rel="noopener"
           class="text-slate-400 hover:text-pink-500 transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 fade-in max-w-xl mx-auto">

      <div class="group flex flex-col items-center text-center">
        <img 
          src="/photo/run.JPG" 
          alt="run" 
          class="w-11/12 aspect-square object-cover rounded-2xl mb-4 border border-slate-200 transition-transform duration-500 group-hover:-translate-y-1 shadow-sm mx-auto"
        />
        <h2 class="font-serif text-2xl text-slate-900 mb-1 lowercase">running</h2>
        <div class="text-[0.8rem] text-slate-500 tracking-wide flex flex-col gap-1">
          <span>training for: 2xu half</span>
          <span>1 x FM | 2 x HM</span>
        </div>
      </div>

      <div class="group flex flex-col items-center text-center">
        <img 
          src="/photo/climb.jpg" 
          alt="climbing" 
          class="w-11/12 aspect-square object-cover rounded-2xl mb-4 border border-slate-200 transition-transform duration-500 group-hover:-translate-y-1 shadow-sm mx-auto"
        />
        <h2 class="font-serif text-2xl text-slate-900 mb-1 lowercase">climbing</h2>
        <div class="text-[0.8rem] text-slate-500 tracking-wide flex flex-col gap-1">
          <span>just having fun</span>
        </div>
      </div>

      <div class="group flex flex-col items-center text-center">
        <img 
          src="/photo/dance.jpg" 
          alt="dance" 
          class="w-11/12 aspect-square object-cover rounded-2xl mb-4 border border-slate-200 transition-transform duration-500 group-hover:-translate-y-1 shadow-sm mx-auto"
        />
        <h2 class="font-serif text-2xl text-slate-900 mb-1 lowercase">dancing</h2>
        <div class="text-[0.8rem] text-slate-500 tracking-wide flex flex-col gap-1">
          <span>ballet, contemp, lyrical, chinese dance</span>
          <span>currently exploring new genres</span>
        </div>
      </div>

      <div class="group flex flex-col items-center text-center">
        <img 
          src="/photo/travel.JPG" 
          alt="travel" 
          class="w-11/12 aspect-square object-cover rounded-2xl mb-4 border border-slate-200 transition-transform duration-500 group-hover:-translate-y-1 shadow-sm mx-auto"
        />
        <h2 class="font-serif text-2xl text-slate-900 mb-1 lowercase">travel</h2>
        <div class="text-[0.8rem] text-slate-500 tracking-wide flex flex-col gap-1">
          <span>41 countries and counting</span>
          <span>where to next?</span>
        </div>
      </div>

    </div>

  </main>

  <footer class="border-t border-slate-200 py-8 px-6 mt-10">
    <div class="max-w-3xl mx-auto flex flex-col justify-center items-center gap-2">
      <span class="text-xs text-slate-500 tracking-widest uppercase">© 2026 Shermaine Ang</span>
    </div>
  </footer>

</Layout>